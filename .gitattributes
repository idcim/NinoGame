# Windows 批处理 / PowerShell / cmd: 强制 CRLF
# 原因: cmd.exe 解析 .bat / .cmd 时, LF-only 行尾会让 `^` 续行符错乱,
# 长 pyinstaller 命令直接散架 (NinoGameAgent / Watchdog 段构建失败).
# 这里显式声明, 避免 core.autocrlf 在不同开发机上行为不一致.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Shell / 跨端文本默认 LF (Docker 容器 / Linux 服务器)
*.sh    text eol=lf

# 二进制 (防 git 当文本处理)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.exe   binary
*.dll   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.7z    binary
*.pdf   binary
*.apk   binary
*.keystore binary
*.jks   binary
