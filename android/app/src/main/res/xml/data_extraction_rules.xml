<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ data_extraction_rules: 跟 backup_rules 一致, 不参与
     云备份 / 设备迁移. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="."/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="."/>
    </device-transfer>
</data-extraction-rules>
