<?xml version="1.0" encoding="utf-8"?>
<!--
  NinoGame Agent 无障碍服务配置.

  事件类型:
    typeWindowStateChanged   — 前台 Activity / Window 切换 (最关键, 抓 package + class)
    typeWindowContentChanged — 窗口内容变化 (可选, 频率高, 这版不用以省电)

  feedbackType: 我们不给用户反馈 (不读屏), 写 feedbackGeneric 占位即可.

  notificationTimeout: 100ms — 收到事件后系统等 100ms 再调 onAccessibilityEvent,
  合并连续事件防抖, 避免一次 app 启动触发 10+ 次回调.

  flags:
    flagIncludeNotImportantViews — 不需要, 我们只看 packageName 不读 view 树
    flagRetrieveInteractiveWindows — 同上, 不需要
    （不设 flag, 性能最好）

  packageNames 留空 = 监听所有 app. 否则白名单具体包.
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:notificationTimeout="100"
    android:canRetrieveWindowContent="false"
    android:description="@string/accessibility_service_description"
    android:summary="@string/accessibility_service_summary" />
