<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 网络: HTTPS + 测试期可走明文 (cleartextTraffic=true 仅 debug) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground Service: Stage 2+ 会持长连接, dataSync 类型最贴合
         (Android 14 起强制声明 type) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 开机自启 (孩子重启平板后 Agent 自动回来) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- 平板 + 手机 + 折叠屏全 OK; Android 自动适配, 不写 supports-screens -->

    <!-- Android 11+ 包可见性: 默认 App 只能看到自己装的 + 系统 app.
         NinoAccessibilityService 要 query 所有 SMS / Dialer / Contacts / IME
         handler 加进 OOT passthrough 列表, 必须显式声明 intent + action -->
    <queries>
        <!-- IME 输入法 -->
        <intent>
            <action android:name="android.view.InputMethod" />
        </intent>
        <!-- 短信 (smsto: handler — Pixel: com.google.android.apps.messaging) -->
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="smsto" />
        </intent>
        <!-- 拨号 -->
        <intent>
            <action android:name="android.intent.action.DIAL" />
        </intent>
        <!-- 通讯录 -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="vnd.android.cursor.dir/contact" />
        </intent>
        <!-- 桌面 launcher (ForegroundAppMonitor.discoverIgnoredPackages 已经用) -->
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.HOME" />
        </intent>
    </queries>

    <application
        android:name=".NinoApp"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.NinoGame"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden|uiMode"
            android:theme="@style/Theme.NinoGame">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- v0.5.1+ Stage 2a: Foreground Service 持 WS 长连接 + 心跳.
             foregroundServiceType=dataSync 是 Android 14+ 必须的类型声明 -->
        <service
            android:name=".service.AgentService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- v0.5.3+ Stage 2c: 开机自启 receiver. RECEIVE_BOOT_COMPLETED 权限已在
             顶部声明; exported=true 是 BOOT_COMPLETED 调起的必要条件 -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <!-- MIUI / 部分国内 ROM 用这个 action 替代 BOOT_COMPLETED -->
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- v0.5.2+ Stage 2b: AccessibilityService 监前台 app.
             用户必须在系统设置 → 无障碍 → 已安装的服务 中手动启用一次.
             权限 BIND_ACCESSIBILITY_SERVICE 系统级保护, 防止其它 App 调起. -->
        <service
            android:name=".service.NinoAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>
</manifest>
