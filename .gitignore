/data/
agent/data/
*.alive
*.db
*.db-shm
*.db-wal

# IDE
.idea/
.vscode/
*.swp
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Docker 数据卷
infra/pgdata/
infra/postgres-data/
# 生产 env (含 DATABASE_URL / JWT_SECRET) 不进库
infra/.env.prod
infra/.env.prod.local

# 用户本地配置（含 PIN / 孩子个人信息 / 自定义文案）
# 首次启动 seed_data 会按默认模板生成
agent/config/settings.json
agent/config/child_profile.json
agent/config/settings.local.json
agent/config/child_profile.local.json

# 调试截图（design/ 仅放设计稿，不放测试输出）
design/screenshot_*.png

# OMC / Claude Code 运行时缓存
.omc/

# TS 增量构建缓存
*.tsbuildinfo
