# NinoGame 生产部署环境变量 (拷贝为 .env.prod 填实际值)
# docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# ── 数据库 ───────────────────────────────────────────────────
# 1Panel 自己有 Postgres 容器, 用容器名连。
# 如果你的 Postgres 容器叫 1panel-postgresql-xxx, 改下面 host 部分。
# 建议在 1Panel 里给本项目建独立 database = ninogame, user = ninogame
DATABASE_URL=postgresql://ninogame:你的强密码@1panel-postgresql:5432/ninogame

# ── JWT (家长登录 token 签名) ─────────────────────────────────
# 务必换一个长随机字符串, openssl rand -hex 32 生成
JWT_SECRET=换成长随机字符串-至少-32-字符
JWT_EXPIRES_IN=7d

# ── 日志 ─────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Docker 网络 ──────────────────────────────────────────────
# 1Panel 默认网络名; 若你在 1Panel 后台看到的网络名不一样改这里
NETWORK_NAME=1panel-network

# ── 时区 ────────────────────────────────────────────────────
TZ=Asia/Shanghai
