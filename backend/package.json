{
  "name": "ninogame-backend",
  "version": "0.1.0",
  "description": "NinoGame Backend (P2) — Fastify + Postgres + WebSocket",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "migrate:up": "node-pg-migrate -j sql -d DATABASE_URL up",
    "migrate:down": "node-pg-migrate -j sql -d DATABASE_URL down",
    "migrate:status": "node-pg-migrate -j sql -d DATABASE_URL status"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/sensible": "^5.5.0",
    "@fastify/websocket": "^10.0.1",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "pg": "^8.12.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "node-pg-migrate": "^7.5.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
