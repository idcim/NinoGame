{
  "name": "ninogame-backend",
  "version": "0.4.10",
  "description": "NinoGame Backend (P2) — Fastify + Postgres + WebSocket",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "migrate:up": "node-pg-migrate -j sql -m sql -d DATABASE_URL up",
    "migrate:down": "node-pg-migrate -j sql -m sql -d DATABASE_URL down",
    "migrate:status": "node-pg-migrate -j sql -m sql -d DATABASE_URL status"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1046.0",
    "@aws-sdk/lib-storage": "^3.1046.0",
    "@aws-sdk/s3-request-presigner": "^3.1046.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/sensible": "^5.5.0",
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^10.0.1",
    "@types/nodemailer": "^8.0.0",
    "ali-oss": "^6.23.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "node-pg-migrate": "^7.5.2",
    "nodemailer": "^6.10.1",
    "pg": "^8.12.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.23.3",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
