# NinoGame Backend 环境变量
# 把本文件拷贝为 .env 并按需修改

# 监听设置 (生产环境配 1Panel 反代, 这里只绑本机)
NODE_ENV=development
HOST=127.0.0.1
PORT=8088

# 数据库 (本地 docker compose 用 5433 端口)
# 生产: 走 1Panel 内 Postgres
DATABASE_URL=postgresql://ninogame:ninogame_dev@127.0.0.1:5433/ninogame

# JWT (家长登录 token 用; 生产换强密钥)
JWT_SECRET=dev-secret-change-me-in-prod
JWT_EXPIRES_IN=7d

# 日志
LOG_LEVEL=info
LOG_PRETTY=true
